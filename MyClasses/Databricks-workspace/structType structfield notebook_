# MAGIC ## 5. Building a Struct Column from Flat Columns
# MAGIC
# MAGIC You already have a flat DataFrame. You want to **group some columns** into a struct.
# MAGIC Use `struct()` from `pyspark.sql.functions`.

# COMMAND ----------

from pyspark.sql.functions import struct

# Take the flat orders_df and pack order_id + status + order_date into a struct called order_meta
structured_df = orders_df.withColumn(
    'order_meta',
    struct(
        col('order_id').alias('id'),
        col('status').alias('order_status'),
        col('order_date').alias('placed_on')
    )
)

structured_df.printSchema()

# COMMAND ----------

# The new struct column appears at the end
structured_df.select('order_id', 'order_meta').show(5, truncate=False)

# COMMAND ----------

# Access sub-fields of the newly created struct — same dot notation
structured_df.select(
    col('order_meta.id'),
    col('order_meta.order_status'),
    col('order_meta.placed_on')
).show(5)

