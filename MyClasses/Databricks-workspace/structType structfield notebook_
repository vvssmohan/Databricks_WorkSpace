# MAGIC %md
# MAGIC ---
# MAGIC ## 7. Array of Structs — Order Line Items
# MAGIC
# MAGIC A very common real-world pattern: **one order has multiple products**.
# MAGIC Instead of one row per product, the order stores an **array of line item structs**.
# MAGIC
# MAGIC ```
# MAGIC root
# MAGIC  |-- order_id:   string
# MAGIC  |-- customer:   string
# MAGIC  |-- line_items: array                    <-- array column
# MAGIC  |    |-- element: struct
# MAGIC  |    |    |-- product_id:   string
# MAGIC  |    |    |-- product_name: string
# MAGIC  |    |    |-- qty:          integer
# MAGIC  |    |    |-- price:        double
# MAGIC ```

# COMMAND ----------

# MAGIC %md
# MAGIC ### 7.1  Dataset 4 — Orders with Line Items Array

# COMMAND ----------

from pyspark.sql.types import ArrayType

order_items_data = [
    Row(order_id='ORD001', customer='Arjun Sharma', city='Hyderabad',
        line_items=[
            Row(product_id='PROD_A', product_name='Basmati Rice 5kg',    qty=2, price=1500.00),
            Row(product_id='PROD_D', product_name='Parle-G Biscuits 800g', qty=3, price=450.00),
        ]),

    Row(order_id='ORD002', customer='Priya Iyer', city='Bangalore',
        line_items=[
            Row(product_id='PROD_B', product_name='Samsung Galaxy M34',  qty=1, price=3200.00),
        ]),

    Row(order_id='ORD003', customer='Rohan Mehta', city='Mumbai',
        line_items=[
            Row(product_id='PROD_C', product_name='Tata Salt 1kg',       qty=3, price=850.00),
            Row(product_id='PROD_F', product_name='Ariel Detergent 2kg', qty=1, price=2200.00),
            Row(product_id='PROD_G', product_name='Maggi Noodles 12pk',  qty=2, price=980.00),
        ]),

    Row(order_id='ORD004', customer='Sneha Reddy', city='Chennai',
        line_items=[
            Row(product_id='PROD_E', product_name='Boat Airdopes 141',   qty=1, price=7500.00),
            Row(product_id='PROD_D', product_name='Parle-G Biscuits 800g', qty=5, price=450.00),
        ]),

    Row(order_id='ORD005', customer='Vikram Nair', city='Pune',
        line_items=[
            Row(product_id='PROD_A', product_name='Basmati Rice 5kg',    qty=1, price=1500.00),
            Row(product_id='PROD_C', product_name='Tata Salt 1kg',       qty=6, price=850.00),
        ]),
]

# COMMAND ----------

# Inner struct schema — each line item
line_item_schema = StructType([
    StructField('product_id',   StringType(),  True),
    StructField('product_name', StringType(),  True),
    StructField('qty',          IntegerType(), True),
    StructField('price',        DoubleType(),  True),
])

# Top-level schema — line_items is an ARRAY of the struct above
order_items_schema = StructType([
    StructField('order_id',   StringType(),            False),
    StructField('customer',   StringType(),            True),
    StructField('city',       StringType(),            True),
    StructField('line_items', ArrayType(line_item_schema), True),
])

items_df = spark.createDataFrame(order_items_data, schema=order_items_schema)
items_df.printSchema()

# COMMAND ----------

items_df.display()

# COMMAND ----------

# MAGIC %md
# MAGIC ### 7.2  Accessing an Array Element by Index

# COMMAND ----------

# Access the FIRST item (index 0) in line_items
items_df.select(
    'order_id',
    col('line_items')[0].alias('first_item')
).display()


items_df.select(
    'order_id',
    col('line_items')[0].alias('first_item')
).select(
    'order_id',
    col('first_item.product_name'),
    col('first_item.qty'),
    col('first_item.price')
).display()

# COMMAND ----------

# MAGIC %md
# MAGIC ### 7.3  `explode()` — One Row Per Array Element
# MAGIC
# MAGIC `explode()` is the key operation for arrays.  
# MAGIC It turns **one row with an array of 3 items** into **3 separate rows**.

# COMMAND ----------

items_df.display()

# COMMAND ----------

from pyspark.sql.functions import explode

# explode turns each element of line_items into its own row
exploded_df = items_df.select(
    'order_id',
    'customer',
    'city',
    explode(col('line_items')).alias('item')   # one row per line item
)

exploded_df.printSchema()
exploded_df.display()

# COMMAND ----------

exploded_df.show(truncate=False)
# Notice: ORD001 now has 2 rows (one per product), ORD003 has 3 rows, etc.

# COMMAND ----------

# MAGIC %md
# MAGIC ### 7.4  Flatten the Struct After Explode

# COMMAND ----------

# After explode, 'item' is a struct — access its sub-fields with dot notation
flat_items = exploded_df.select(
    'order_id',
    'customer',
    'city',
    col('item.product_id').alias('product_id'),
    col('item.product_name').alias('product_name'),
    col('item.qty').alias('qty'),
    col('item.price').alias('price')
)

flat_items.show(truncate=False)

# COMMAND ----------

# Calculate line total for each item
from pyspark.sql.functions import round as spark_round

flat_items_with_total = flat_items.withColumn(
    'line_total',
    spark_round(col('qty') * col('price'), 2)
)

flat_items_with_total.show(truncate=False)

# COMMAND ----------

# MAGIC %md
# MAGIC ### 7.5  Aggregate After Explode

# COMMAND ----------

from pyspark.sql.functions import sum as spark_sum, count

# Total revenue per order
flat_items_with_total.groupBy('order_id', 'customer') \
    .agg(
        spark_sum('line_total').alias('order_total'),
        count('product_id').alias('num_items')
    ) \
