# MAGIC %md
# MAGIC ---
# MAGIC ## 6. Parsing a JSON String Column into a Struct  (`from_json`)
# MAGIC
# MAGIC **Real-world scenario:** Data arrives from a Kafka topic or REST API as a STRING column
# MAGIC containing a JSON payload. We use `from_json()` to turn that string into a struct.

# COMMAND ----------

# MAGIC %md
# MAGIC ### 6.1  Dataset 3 — Raw Orders with a JSON Payload Column

# COMMAND ----------

# Simulate: each row has an order_id and a 'payload' column that is a JSON string
raw_data = [
    ('ORD001', '{"customer":"Arjun Sharma","city":"Hyderabad","amount":3000.0,"status":"Delivered"}'),
    ('ORD002', '{"customer":"Priya Iyer","city":"Bangalore","amount":3200.0,"status":"Pending"}'),
    ('ORD003', '{"customer":"Rohan Mehta","city":"Mumbai","amount":2550.0,"status":"Delivered"}'),
    ('ORD004', '{"customer":"Sneha Reddy","city":"Chennai","amount":1500.0,"status":"Cancelled"}'),
    ('ORD005', '{"customer":"Vikram Nair","city":"Pune","amount":2250.0,"status":"Delivered"}'),
    ('ORD006', '{"customer":"Kavya Rao","city":"Hyderabad","amount":6400.0,"status":"Delivered"}'),
]

raw_schema = StructType([
    StructField('order_id', StringType(), False),
    StructField('payload',  StringType(), True),   # the JSON string lives here
])

raw_df = spark.createDataFrame(raw_data, schema=raw_schema)
raw_df.show(truncate=False)

# COMMAND ----------

# Define the schema of the JSON INSIDE the payload column
from pyspark.sql.functions import from_json, to_json

payload_schema = StructType([
    StructField('customer', StringType(), True),
    StructField('city',     StringType(), True),
    StructField('amount',   DoubleType(), True),
    StructField('status',   StringType(), True),
])

# Parse the JSON string into a proper struct column called 'data'
parsed_df = raw_df.withColumn('data', from_json(col('payload'), payload_schema))

parsed_df.printSchema()

# COMMAND ----------

parsed_df.display()
# Notice: 'data' column is now a struct, not a raw string

# COMMAND ----------

# Access the parsed fields using dot notation — exactly the same as Section 4
parsed_df.select(
    'order_id',
    col('data.customer').alias('customer_name'),
    col('data.city').alias('city'),
    col('data.amount').alias('order_amount'),
    col('data.status').alias('status')
).show(truncate=False)

