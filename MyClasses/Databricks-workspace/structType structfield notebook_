# MAGIC %md
# MAGIC ### 4.2  Defining the Nested Schema

# COMMAND ----------

# Step 1 — Define the INNER struct schema (for shipping_address)
address_schema = StructType([
    StructField('street',  StringType(), True),
    StructField('city',    StringType(), True),
    StructField('pincode', StringType(), True),
    StructField('state',   StringType(), True),
])

# Step 2 — Define the OUTER (top-level) schema
#           The shipping_address column's dataType = address_schema
orders_address_schema = StructType([
    StructField('order_id',         StringType(),  False),
    StructField('customer_id',      StringType(),  True),
    StructField('city',             StringType(),  True),
    StructField('quantity',         IntegerType(), True),
    StructField('unit_price',       DoubleType(),  True),
    StructField('status',           StringType(),  True),
    StructField('shipping_address', address_schema, True),   # <-- NESTED STRUCT
])

# Step 3 — Create the DataFrame
orders_addr_df = spark.createDataFrame(orders_with_address_data,
                                       schema=orders_address_schema)

# COMMAND ----------

# Run printSchema — notice the indented sub-fields under shipping_address
