    col('shipping_address.city').alias('ship_city'),
    col('shipping_address.pincode').alias('ship_pincode'),
    col('shipping_address.state').alias('ship_state')
)

flat_df.printSchema()   # no more struct — all columns are flat
flat_df.display()

