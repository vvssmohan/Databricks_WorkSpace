# When you want to completely replace the table schema (structure change)
# overwriteSchema=true is required — otherwise the write is rejected
from pyspark.sql import functions as F
 
# Read current data, transform, add new column, drop old column
transformed_df = spark.table('retail_db.orders') \
    .withColumn('order_amount', F.round(F.col('quantity') * F.col('unit_price'), 2)) \
    .drop('unit_price')    # removing a column from the schema
 
transformed_df.write \
    .format('delta') \
    .mode('overwrite') \
    .option('overwriteSchema', 'true') \
    .saveAsTable('retail_db3.orders')
 
spark.sql('DESCRIBE TABLE retail_db.orders').show(truncate=False)
