from delta.tables import DeltaTable
 
# Build the source DataFrame (the incoming supplier feed)
feed_data = [
    ('PROD_C', 'Tata Salt 1kg',    'Grocery', 'Tata Consumer', 940.00, 5),
    ('PROD_J', 'Amul Butter 500g', 'Grocery', 'Amul',          320.00, 5),
    ('PROD_K', 'Britannia Bread',  'FMCG',    'Britannia',      55.00, 5),
]
feed_schema = StructType([
    StructField('product_id',   StringType(),  True),
    StructField('product_name', StringType(),  True),
    StructField('category',     StringType(),  True),
    StructField('brand',        StringType(),  True),
    StructField('base_price',   DoubleType(),  True),
    StructField('gst_pct',      IntegerType(), True),
])
feed_df = spark.createDataFrame(feed_data, schema=feed_schema)
 
# Get a handle on the target Delta table
delta_products = DeltaTable.forName(spark, 'retail_db3.products')
 
# Execute the MERGE
delta_products.alias('target') \
    .merge(
        feed_df.alias('source'),
        'target.product_id = source.product_id'     # join key
    ) \
    .whenMatchedUpdate(set={
        'base_price':   'source.base_price',
        'product_name': 'source.product_name'
    }) \
    .whenNotMatchedInsertAll().execute()
 
spark.table('retail_db3.products').show()


